# RabbitMQ credentials (used by docker-compose)
# Copy this file to .env and change values in non-local environments.
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# Consumer Worker - RabbitMQ Host (required for consumer-worker)
SPRING_RABBITMQ_HOST=nombre_del_servicio_rabbitmq

# Consumer Worker - PostgreSQL datasource (required for consumer-worker)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/sofkianos_db
SPRING_DATASOURCE_USERNAME=your_db_username
SPRING_DATASOURCE_PASSWORD=your_db_password
SPRING_DATASOURCE_DATABASE_NAME=your_db_name
